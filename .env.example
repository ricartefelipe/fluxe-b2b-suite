# ============================================================
# Fluxe B2B Suite — Environment Variables (docker-compose.prod.yml)
# ============================================================
# Copy to .env and fill in the values before running
# docker-compose.prod.yml (VM ou servidor próprio — não commitar .env real).
# Railway: usar railway.prod.env.example por serviço + docs/GO-LIVE-VENDA.md.
# ============================================================

# --- Domain & TLS (nginx / Keycloak hostname) ---
DOMAIN=fluxe.example.com

# --- Database (shared PostgreSQL) ---
DB_USER=fluxe
DB_PASSWORD=CHANGE_ME_db_password

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- RabbitMQ ---
RABBITMQ_USER=fluxe
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password

# --- Keycloak (OIDC provider) ---
KEYCLOAK_HOSTNAME=auth.fluxe.example.com
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin

# --- OIDC / JWT (mesmo JWT_SECRET nos 3 backends em HS256 / resource server) ---
OIDC_ISSUER_URI=https://auth.fluxe.example.com/realms/fluxe
# Keycloak JWKS — obrigatório em produção com AUTH_MODE=oidc no Core:
OIDC_JWK_SET_URI=https://auth.fluxe.example.com/realms/fluxe/protocol/openid-connect/certs
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
JWT_ISSUER=spring-saas-core
JWT_SECRET=CHANGE_ME_min_32_chars_openssl_rand_base64_32

# --- CORS — lista CSV das origens públicas HTTPS dos 3 fronts + auth ---
# Ex.: https://shop.example.com,https://ops.example.com,https://admin.example.com,https://auth.example.com
CORS_ALLOWED_ORIGINS=https://fluxe.example.com

# --- Email transacional (Core — convites, reset; provider RESEND em prod) ---
EMAIL_PROVIDER=log
RESEND_API_KEY=
EMAIL_FROM=noreply@fluxe.example.com
FRONTEND_URL=https://admin.fluxe.example.com

# --- Billing Stripe (Core — portal / assinaturas; separado da STRIPE_API_KEY do ledger) ---
APP_BILLING_PROVIDER=stripe
STRIPE_BILLING_SECRET_KEY=

# --- Container images (GHCR) ---
GHCR_ORG=ricartefelipe
SAAS_CORE_TAG=latest
ORDERS_TAG=latest
PAYMENTS_TAG=latest

# --- Payment gateway (py-payments-ledger) ---
GATEWAY_PROVIDER=fake
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
ENCRYPTION_KEY=

# --- Observabilidade ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana

SENTRY_DSN_CORE=
SENTRY_DSN_ORDERS=
SENTRY_DSN_PAYMENTS=
