# =============================================================================
# Fluxe B2B Suite — Production Environment Variables
# Copy to .env and fill in all required values before deploying.
# =============================================================================

# --- Domain & Networking ---
DOMAIN=fluxe.example.com

# --- GHCR (GitHub Container Registry) ---
GHCR_ORG=your-github-org

# --- Image Tags (override to pin a specific version) ---
SAAS_CORE_TAG=latest
ORDERS_TAG=latest
PAYMENTS_TAG=latest

# --- PostgreSQL ---
DB_USER=fluxe
DB_PASSWORD=                          # REQUIRED: strong password

# --- Redis ---
REDIS_PASSWORD=                       # REQUIRED: strong password

# --- RabbitMQ ---
RABBITMQ_USER=fluxe
RABBITMQ_PASSWORD=                    # REQUIRED: strong password

# --- Keycloak ---
KEYCLOAK_HOSTNAME=auth.fluxe.example.com
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=              # REQUIRED: strong password

# --- OIDC / JWT ---
OIDC_ISSUER_URI=https://auth.fluxe.example.com/realms/fluxe-b2b
JWT_SECRET=                           # REQUIRED: shared secret (min 32 chars), must match across all services
JWT_ISSUER=spring-saas-core

# --- CORS ---
# Comma-separated list of allowed frontend origins (NEVER use * in production)
CORS_ALLOWED_ORIGINS=https://fluxe.example.com,https://ops.fluxe.example.com,https://admin.fluxe.example.com

# --- Payments (Stripe) ---
GATEWAY_PROVIDER=fake                 # Set to "stripe" for real payments
STRIPE_API_KEY=                       # Required if GATEWAY_PROVIDER=stripe
STRIPE_WEBHOOK_SECRET=                # Required if GATEWAY_PROVIDER=stripe

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=                     # REQUIRED: strong password

# --- Sentry (optional) ---
SENTRY_DSN_CORE=
SENTRY_DSN_ORDERS=
SENTRY_DSN_PAYMENTS=

# --- Deploy Target ---
# Para Oracle Cloud Free Tier (Ampere A1):
#   1. Criar instância: 4 OCPU, 24GB RAM, 200GB boot volume, Ubuntu 22.04 aarch64
#   2. Configurar VCN Security List: abrir portas 22, 80, 443
#   3. SSH: ssh ubuntu@<public-ip>
#   4. Rodar deploy/server-setup.sh como root
#   5. Copiar este .env, preencher, e rodar scripts/deploy.sh
DEPLOY_HOST=                          # Server IP or hostname
DEPLOY_SSH_USER=fluxe                 # User created by server-setup.sh
DEPLOY_PATH=/opt/fluxe
