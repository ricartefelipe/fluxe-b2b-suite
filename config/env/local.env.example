# =============================================================================
# Variáveis para ambiente LOCAL
# Infra: Postgres/Redis/Rabbit via spring-saas-core/docker-compose (portas no host abaixo).
# Apps: rodando na sua máquina (Core 8080, Orders 3000, Payments 8000).
# =============================================================================
# Use como referência. Para node-b2b-orders: copie para .env.local no repo.
# Para spring-saas-core: já está em application.yml; use SPRING_PROFILES_ACTIVE=local.
# =============================================================================

# ---- Infra (host) ----
# Postgres (porta 5435 no host = 5432 no container)
POSTGRES_HOST=localhost
POSTGRES_PORT=5435

# Redis (porta 6382 no host)
REDIS_HOST=localhost
REDIS_PORT=6382

# RabbitMQ (porta 5675 no host para AMQP)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5675

# ---- spring-saas-core (já em application.yml com estes defaults) ----
# DB_URL=jdbc:postgresql://localhost:5435/saascore
# REDIS_HOST=localhost REDIS_PORT=6382
# RABBITMQ_HOST=localhost RABBITMQ_PORT=5675
# Servidor: 8080

# ---- node-b2b-orders: use no .env.local ----
DATABASE_URL=postgresql://app:app@localhost:5435/app
REDIS_URL=redis://localhost:6382
RABBITMQ_URL=amqp://guest:guest@localhost:5675

# JWT (igual ao Core para aceitar tokens)
JWT_SECRET=local-dev-secret-min-32-chars-for-hs256-signing
JWT_ISSUER=spring-saas-core

# ---- Front (saas-suite-ui) ----
# Em dev o proxy usa /api/core -> 8080, /api/orders -> 3000, /api/payments -> 8000.
# config.json deve ter: coreApiBaseUrl=/api/core, ordersApiBaseUrl=/api/orders, paymentsApiBaseUrl=/api/payments
# Para gerar config a partir de env: CORE_API_BASE_URL=http://localhost:8080 ORDERS_API_BASE_URL=http://localhost:3000 npm run generate-config (ou scripts/generate-config.sh)

# ---- py-payments-ledger (se rodar local) ----
# DATABASE_URL=postgresql+psycopg://app:app@localhost:5435/payments
# REDIS_URL=redis://localhost:6382/0
# RABBITMQ_URL=amqp://guest:guest@localhost:5675
# Criar database payments no mesmo Postgres se necessário
