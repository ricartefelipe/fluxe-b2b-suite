{
  "uid": "b2b-orders",
  "title": "B2B Suite — Orders",
  "description": "Orders service metrics: creation rate, status distribution, inventory, and jobs",
  "tags": ["b2b-suite", "orders"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(b2b_orders_created_total, tenant_id)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Orders Created per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "gradientMode": "scheme" },
          "unit": "opm",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(b2b_orders_created_total{tenant_id=~\"$tenant_id\"}[1m])) * 60",
          "legendFormat": "Orders / min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Order Status Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum by (status) (b2b_orders_by_status{tenant_id=~\"$tenant_id\"})",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Average Order Amount",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyBRL",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "b2b_orders_amount_sum{tenant_id=~\"$tenant_id\"} / b2b_orders_amount_count{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "Avg amount",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Top Products by Order Count",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "transformations": [
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } },
        { "id": "limit", "options": { "limitField": 10 } }
      ],
      "targets": [
        {
          "expr": "topk(10, sum by (product_id) (b2b_orders_items_total{tenant_id=~\"$tenant_id\"}))",
          "legendFormat": "{{ product_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Inventory Alerts (Low Stock)",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "green", "value": 50 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": false }]
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "Value", "desc": false }] }
        }
      ],
      "targets": [
        {
          "expr": "b2b_inventory_available_qty{tenant_id=~\"$tenant_id\"} < 20",
          "legendFormat": "{{ sku }}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Import / Export Job Status",
      "type": "state-timeline",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "IDLE", "color": "transparent" },
                "1": { "text": "RUNNING", "color": "blue" },
                "2": { "text": "SUCCESS", "color": "green" },
                "3": { "text": "FAILED", "color": "red" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "center",
        "rowHeight": 0.8
      },
      "targets": [
        {
          "expr": "b2b_import_export_job_status{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{ job_type }} — {{ job_name }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
