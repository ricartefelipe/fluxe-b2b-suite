{
  "uid": "b2b-overview",
  "title": "B2B Suite — Overview",
  "description": "High-level health and performance view of all Fluxe B2B services",
  "tags": ["b2b-suite", "overview"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(http_server_requests_seconds_count, tenant_id)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "up{job=~\"saas-core|orders-api|payments-api\"}",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{tenant_id=~\"$tenant_id\"}[5m]))",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate per Service (5xx %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\", tenant_id=~\"$tenant_id\"}[5m])) / sum by (job) (rate(http_server_requests_seconds_count{tenant_id=~\"$tenant_id\"}[5m]))",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (job, le) (rate(http_server_requests_seconds_bucket{tenant_id=~\"$tenant_id\"}[5m])))",
          "legendFormat": "{{ job }} — P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_server_requests_seconds_bucket{tenant_id=~\"$tenant_id\"}[5m])))",
          "legendFormat": "{{ job }} — P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_server_requests_seconds_bucket{tenant_id=~\"$tenant_id\"}[5m])))",
          "legendFormat": "{{ job }} — P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Connections / SSE Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum by (job) (http_server_active_connections{tenant_id=~\"$tenant_id\"})",
          "legendFormat": "{{ job }} connections",
          "refId": "A"
        },
        {
          "expr": "sum(b2b_sse_active_clients{tenant_id=~\"$tenant_id\"})",
          "legendFormat": "SSE clients",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "RabbitMQ Queue Depths",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages",
          "legendFormat": "{{ queue }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
