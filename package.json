{
  "name": "fluxe-b2b-suite",
  "version": "1.0.0",
  "private": true,
  "description": "Fluxe B2B Suite — plataforma B2B multi-tenant (shop, ops-portal, admin-console)",
  "scripts": {
    "dev": "cd saas-suite-ui && pnpm nx serve ops-portal",
    "dev:shop": "cd saas-suite-ui && pnpm nx serve shop",
    "dev:admin": "cd saas-suite-ui && pnpm nx serve admin-console",
    "install:ui": "cd saas-suite-ui && pnpm install",
    "e2e:local": "bash scripts/run-e2e-local.sh",
    "verify:all": "bash scripts/pre-merge-checks.sh",
    "verify:go-live": "bash scripts/go-live-production-verify.sh",
    "verify:contracts": "bash scripts/check-contract-drift.sh",
    "smoke:staging": "bash scripts/smoke-staging.sh",
    "smoke:order-staging": "bash scripts/smoke-order-staging.sh",
    "smoke:order-staging:paid": "env SMOKE_PAYMENT_PAID=1 bash scripts/smoke-order-staging.sh",
    "smoke:order-staging:saga": "env SMOKE_SAGA_PAID_LEDGER=1 bash scripts/smoke-order-staging.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ricartefelipe/fluxe-b2b-suite.git"
  },
  "license": "MIT"
}
