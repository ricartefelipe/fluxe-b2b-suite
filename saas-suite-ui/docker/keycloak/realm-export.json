      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost:4300",
        "http://localhost:4400"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*##http://localhost:4300/*##http://localhost:4400/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "fluxe-claims"
      ]
    }
  ],
