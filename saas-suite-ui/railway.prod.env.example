# === fluxe-b2b-suite Frontends — Railway Environment Variables ===
# Configurar as mesmas variáveis nos 3 serviços (shop, admin-console, ops-portal)

# URLs dos backends no Railway (substituir pelos URLs reais após deploy)
CORE_API_BASE_URL=https://spring-saas-core.up.railway.app
ORDERS_API_BASE_URL=https://node-b2b-orders.up.railway.app
PAYMENTS_API_BASE_URL=https://py-payments-ledger.up.railway.app

# Auth mode — hs256 para dev, oidc para produção
AUTH_MODE=hs256

# OIDC (quando usar Keycloak/Auth0)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_SCOPE=openid profile email

LOG_LEVEL=warn
APP_VERSION=1.0.0
