# === fluxe-b2b-suite Frontends — Railway Environment Variables ===
# Configurar as mesmas variáveis nos 3 serviços (shop, admin-console, ops-portal)
# Produção com domínio próprio: substituir pelos URLs reais. Ver docs/URLS-PRODUCAO.md e GO-LIVE-VENDA.md.

# URLs dos backends no Railway — projecto Production (confirmar em docs/URLS-PRODUCAO.md)
# Com URLs https://, o build injeta /api/... no config.json (same-origin) e o Shop (Node) / Nginx
# (ops, admin) reencaminha para estes alvos — o browser nao recebe HTML da SPA em /api/*.
CORE_API_BASE_URL=https://spring-saas-core-production.up.railway.app
ORDERS_API_BASE_URL=https://node-b2b-orders-production.up.railway.app
PAYMENTS_API_BASE_URL=https://py-payments-ledger-production.up.railway.app

# Auth: hs256 para staging/demo; oidc para produção (recomendado)
AUTH_MODE=oidc

# Shop: opcional — e-mail da página Fale conosco e URL da documentação/ajuda
# SUPPORT_EMAIL=suporte@seudominio.com.br
# SUPPORT_DOCS_URL=https://docs.seudominio.com

# OIDC (obrigatório se AUTH_MODE=oidc — produção). Exemplo:
# OIDC_ISSUER=https://auth.seudominio.com.br/realms/fluxe
# OIDC_CLIENT_ID=fluxe-b2b-suite
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_SCOPE=openid profile email

LOG_LEVEL=warn
APP_VERSION=1.0.0
